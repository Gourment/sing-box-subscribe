    "rules": [
      {
        "outbound": "any",
        "server": "localDns"
      },
      {
        "clash_mode": "Direct",
        "server": "localDns"
      },
      {
        "clash_mode": "Global",
        "server": "proxyDns"
      },
      {
        "rule_set": [
          "geosite-cn",
          "chinadomain"
        ],
        "server": "localDns"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": "geolocation-!cn",
            "invert": true
          },
          {
            "rule_set": "geoip-cn"
          }
        ],
        "server": "proxyDns",
        "client_subnet": "114.114.114.114/24"
      }
    ],
    "final": "proxyDns",
    "reverse_mapping": true,
    "disable_cache": false,
    "disable_expire": false,
    "strategy": "prefer_ipv4"
  },    
