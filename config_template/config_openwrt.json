{
  "log": {
    "level": "debug",
    "timestamp": true
  },
  "ntp": {
    "enabled": true,
    "server": "ntp.aliyun.com",
    "server_port": 123,
    "interval": "30m",
    "detour": "🎯 直连"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "",
      "store_fakeip": false
    },
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "external_ui": "ui",
      "external_ui_download_url": "",
      "external_ui_download_detour": "🌏 国际代理",
      "secret": "",
      "default_mode": "Rule"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "proxyDns",
        "address": "tls://1.1.1.1",
        "detour": "🌏 国际代理"
      },
      {
        "tag": "localDns",
        "address": "https://223.5.5.5/dns-query",
        "detour": "🎯 直连"
      },
      {
        "tag": "block",
        "address": "rcode://success"
      }
    ],
    "rules": [
      {
        "rule_set": "category-ads-all",
        "server": "block",
        "disable_cache": true
      },
      {
        "outbound": "any",
        "server": "localDns",
        "disable_cache": true
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": "geolocation-!cn",
            "invert": true
          },
          {
            "rule_set": [
              "geosite-cn",
              "chinadomain",
              "category-companies@cn"
            ]
          }
        ],
        "server": "localDns"
      },
      {
        "clash_mode": "Direct",
        "server": "localDns"
      },
      {
        "clash_mode": "Global",
        "server": "proxyDns"
      },
      {
        "rule_set": "geolocation-!cn",
        "server": "proxyDns"
      }
    ],
    "independent_cache": true,
    "strategy": "ipv4_only"
  },    
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "inet4_address": "172.19.0.1/30",
      "inet6_address": "fdfe:dcba:9876::1/126",
      "mtu": 9000,
      "auto_route": true,
      "strict_route": false,
      "sniff": true,
      "stack": "mixed",
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 2080
        }
      }
    },
    {
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 2080,
      "sniff": true,
      "users": []
    }
  ],
  "outbounds": [
    {
      "tag": "♾️ Others",
      "type": "selector",
      "outbounds": [
        "⚡ 自动测速",
        "🕹 手动切换",
